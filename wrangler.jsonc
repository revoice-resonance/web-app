{
  // ===========================================================================
  // Project Resonance — Cloudflare Worker 配置
  // ===========================================================================
  // 部署命令：pnpm build && cd worker && wrangler deploy
  // 本地开发：cd worker && wrangler dev
  //
  // Secret（务必在首次部署前通过 CLI 注入，永远不写进本文件）：
  //   wrangler secret put WHISPER_API_KEY    # Whisper ASR API Key
  //   wrangler secret put COSYVOICE_API_KEY  # CosyVoice TTS API Key
  // ===========================================================================

  "name": "project-resonance-api",
  "main": "./worker/src/index.ts",
  "compatibility_date": "2025-04-28",

  // 静态资源：Vite 构建产物
  "assets": {
    "directory": "./frontend/dist"
  },

  // ---------------------------------------------------------------------------
  // VPC 服务绑定（已废弃，改用 Whisper ASR + CosyVoice TTS 云 API）
  // ---------------------------------------------------------------------------
  "vpc_services": [],

  // ---------------------------------------------------------------------------
  // 环境变量（只放公开/非敏感值，Secret 通过 `wrangler secret put` 注入）
  //
  // 必配 Secret：
  //   WHISPER_API_KEY        — Whisper ASR API Key
  //   COSYVOICE_API_KEY      — CosyVoice TTS API Key
  //
  // 可选覆盖（通过 secret put 注入同名变量即可覆盖默认值）：
  //   WHISPER_BASE_URL             — 默认 https://api.openai.com/v1
  //   WHISPER_ASR_DEFAULT_MODEL    — 默认 whisper-1
  //   COSYVOICE_BASE_URL           — 默认 https://api.openai.com/v1
  //   COSYVOICE_DEFAULT_MODEL      — 默认 tts-1
  //   COSYVOICE_DEFAULT_VOICE      — 默认 alloy
  // ---------------------------------------------------------------------------
  // D1 数据库绑定（STORAGE_BACKEND=d1 时取消注释）：
  // "d1_databases": [
  //   { "binding": "RESONANCE_D1", "database_name": "resonance-db", "database_id": "<your-d1-database-id>" }
  // ],
  // KV 命名空间绑定（STORAGE_BACKEND=d1 时用于 rate-limit 计数器）：
  // "kv_namespaces": [
  //   { "binding": "RESONANCE_KV", "id": "<your-kv-namespace-id>" }
  // ],
  // ---------------------------------------------------------------------------
  "vars": {}
}