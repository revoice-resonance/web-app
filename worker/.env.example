# Project Resonance Worker 环境变量模板
# 复制此文件为 .env 并填写实际值（仅用于开发）
# 生产环境请使用 wrangler secret put 设置环境变量

# =============================================================================
# AI 服务配置
# =============================================================================

# Gemini ASR 备用服务 URL（可选）
# 格式：https://your-gemini-asr-endpoint.com
GEMINI_ASR_URL=

# Gemini ASR 认证密钥（可选）
GEMINI_ASR_KEY=

# =============================================================================
# VPC 服务配置（在 wrangler.jsonc 中配置）
# =============================================================================

# 以下服务通过 VPC 绑定配置，无需在此设置环境变量：
# - WHISPER_VPC: Whisper 语音识别服务
# - COSYVOICE_VPC: CosyVoice 语音合成服务

# =============================================================================
# 开发配置
# =============================================================================

# Cloudflare 账户 ID（部署时需要）
CLOUDFLARE_ACCOUNT_ID=

# 部署域名（自定义域名）
WORKER_DOMAIN=

# =============================================================================
# 重要说明
# =============================================================================

# 1. 生产环境不要使用 .env 文件，使用 wrangler secret put 设置敏感信息
# 2. VPC 服务在 wrangler.jsonc 中配置，无需环境变量
# 3. 所有环境变量都通过 wrangler.toml 或 wrangler secret 管理