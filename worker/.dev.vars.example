# =============================================================================
# Project Resonance Worker — 本地开发环境变量
# =============================================================================
# 1. cp worker/.dev.vars.example worker/.dev.vars
# 2. 填入实际值
# 3. worker/.dev.vars 已加入 .gitignore，绝不会提交
# 4. `wrangler dev` 启动时自动读取
# =============================================================================

# -----------------------------------------------------------------------------
# Whisper ASR API Key（必须）
# -----------------------------------------------------------------------------
WHISPER_API_KEY=sk-your-whisper-key-here

# -----------------------------------------------------------------------------
# Whisper 可选配置（不填走代码默认值）
# -----------------------------------------------------------------------------
# WHISPER_BASE_URL=https://api.openai.com/v1
# WHISPER_ASR_DEFAULT_MODEL=whisper-1

# -----------------------------------------------------------------------------
# CosyVoice TTS API Key（必须）
# -----------------------------------------------------------------------------
COSYVOICE_API_KEY=sk-your-cosyvoice-key-here

# -----------------------------------------------------------------------------
# CosyVoice 可选配置（不填走代码默认值）
# -----------------------------------------------------------------------------
# COSYVOICE_BASE_URL=https://api.openai.com/v1
# COSYVOICE_DEFAULT_MODEL=tts-1
# COSYVOICE_DEFAULT_VOICE=alloy

# -----------------------------------------------------------------------------
# MinIO 对象存储（语料收集）
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# MINIO_ENDPOINT=
# MINIO_PORT=
# MINIO_USE_SSL=
# MINIO_BUCKET_NAME=
# MINIO_REGION=

# -----------------------------------------------------------------------------
# 存储后端: "pg" (Hyperdrive/PostgreSQL) 或 "d1" (Cloudflare D1 + KV, 默认)
# STORAGE_BACKEND=d1

# JWT 签名密钥（HS256），生产环境通过 `wrangler secret put JWT_SECRET` 注入
# JWT_SECRET=dev-secret-change-me

# 安全配置（可选）
# -----------------------------------------------------------------------------
# ALLOWED_ORIGIN=
# API_KEY=