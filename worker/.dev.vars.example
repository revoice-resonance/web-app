# =============================================================================
# Project Resonance Worker — 本地开发环境变量
# =============================================================================
# 1. cp worker/.dev.vars.example worker/.dev.vars
# 2. 填入实际值
# 3. worker/.dev.vars 已加入 .gitignore，绝不会提交
# 4. `wrangler dev` 启动时自动读取
# =============================================================================

# -----------------------------------------------------------------------------
# CloudSpeech API Key（必须 —— ASR + TTS 共用）
# 从 https://platform.cloud-speech.com 获取 → 个人中心 → API Keys
# -----------------------------------------------------------------------------
CLOUD_SPEECH_API_KEY=sk-your-cloud-speech-key-here

# -----------------------------------------------------------------------------
# CloudSpeech 可选配置（不填走代码默认值）
# -----------------------------------------------------------------------------
# CLOUD_SPEECH_BASE_URL=https://api.cloud-speech.com/v1
# CLOUD_SPEECH_DEFAULT_MODEL=step-tts-mini
# CLOUD_SPEECH_DEFAULT_VOICE=wenrounvsheng
# CLOUD_SPEECH_ASR_DEFAULT_MODEL=stepaudio-2.5-asr

# -----------------------------------------------------------------------------
# Gemini ASR（已弃用，仅本地兼容老版本）
# -----------------------------------------------------------------------------
# GEMINI_ASR_URL=
# GEMINI_ASR_KEY=

# -----------------------------------------------------------------------------
# MinIO 对象存储（语料收集）
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# MINIO_ENDPOINT=
# MINIO_PORT=
# MINIO_USE_SSL=
# MINIO_BUCKET_NAME=
# MINIO_REGION=

# -----------------------------------------------------------------------------
# 安全配置（可选）
# -----------------------------------------------------------------------------
# ALLOWED_ORIGIN=
# API_KEY=
