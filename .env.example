# =============================================================================
# Project Resonance — Environment Variables Template
# =============================================================================
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored. NEVER commit real keys.
#
# This project is designed to be portable: it runs on Cloudflare Pages/Workers,
# Vercel, Netlify, self-hosted Node, or any static host. No values below are
# tied to Lovable.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite) — exposed to the browser, must be public-safe (anon keys only)
# -----------------------------------------------------------------------------

# Your Supabase (or Supabase-compatible) project URL
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon / publishable key — safe to ship to the browser
VITE_SUPABASE_PUBLISHABLE_KEY=<your_anon_key>

# Project ref (the subdomain part of the URL above)
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# -----------------------------------------------------------------------------
# Cloudflare Worker — set via `wrangler secret put <NAME>`, NOT in this file
# -----------------------------------------------------------------------------
# Used by worker/whisper-asr.ts as ASR fallback when self-hosted Whisper is down.
#
#   wrangler secret put GEMINI_ASR_URL   # e.g. https://xxx.supabase.co/functions/v1/gemini-asr
#   wrangler secret put GEMINI_ASR_KEY   # bearer token for that endpoint
#
# Both are optional. If unset, ASR fallback is disabled and the worker returns
# a clear error envelope when Whisper is unreachable.

# -----------------------------------------------------------------------------
# Edge Functions (Supabase / Deno Deploy) — set via your platform's secret UI
# -----------------------------------------------------------------------------
#   GEMINI_API_KEY   — Google AI Studio key, https://aistudio.google.com/apikey
#                      (required by supabase/functions/gemini-asr)
#   WHISPER_API_URL  — Optional public Whisper server URL
#                      (used by supabase/functions/whisper-asr if no VPC binding)
#   COSYVOICE_API_URL — Optional public CosyVoice server URL
